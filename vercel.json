{
  "version": 2,
  "name": "sumipanel-admin",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/admin.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/login", "destination": "/admin.html" }
  ]
}
